}function sendDetailsToTrainer() {
    // 1. Get the values the user typed in
    const name = document.getElementById('cust-name').value;
    const goal = document.getElementById('cust-goal').value;
    const trainerNum = "919902837507"; // The number you providedument.getElementById('cust-name').value;
    const goal = document.getElementById('cust-goal').value;
    const trainerNum = "919902837507"; // The number you provided

    // 2. Check if the name is empty
    if (name === "") {
        alert("Please enter your name first!");
        return;
    }

    // 3. Create the professional message
    const message = `Hi! My name is ${name}. I want to join the gym for ${goal}. Please send me the joining details.`;
    
    // 4. Encode and Redirect to WhatsApp
    const encodedMsg = encodeURIComponent(message);
    const finalUrl = `https://api.whatsapp.com/send?phone=${trainerNum}&text=${encodedMsg}`;

    // 5. Open WhatsApp
    window.open(finalUrl, '_top');
}
